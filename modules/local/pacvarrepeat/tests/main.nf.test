import java.nio.file.Path

nextflow_process {

    name "Test Process PACVAR_REPEAT"
    script "../main.nf"
    process "PACVAR_REPEAT"

    tag "modules"
    tag "pacvarrepeat"

    test("nf-core/pacvar output reporting [meta, vcf_file]") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://github.com/nf-cmgg/test-datasets/raw/refs/heads/main/data/genomics/homo_sapiens/pacvar_repeat/run1/trgt/sample1A.vcf.gz', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                {
                    def tuple = process.out.excels[0]
                    def meta = tuple[0]
                    def xlsx = tuple[1] instanceof Path ? tuple[1] : file(tuple[1])
                    def metaSnap = [
                        metaValue : meta,
                        xlsxName : xlsx.name,
                        xlsxSize : xlsx.size()
                    ]
                    assert snapshot(metaSnap).match()
                }
            )
        }
    }

    test("stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://github.com/nf-cmgg/test-datasets/raw/refs/heads/main/data/genomics/homo_sapiens/pacvar_repeat/run1/trgt/sample1A.vcf.gz', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
