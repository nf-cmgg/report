{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-cmgg/report/master/assets/schema_input.json",
    "title": "nf-cmgg/report pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "cram": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.cram$"
            },
            "crai": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.crai$"
            },
            "design": {
                "type": "string"
            }
        },
        "required": ["sample", "cram", "crai"]
    }
}
